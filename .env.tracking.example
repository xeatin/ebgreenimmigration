# Tracking + Kommo handoff
# Copy this file to .env.tracking.local.
# This version is aligned with the current execution mode:
# qualified lead: site (Vite) -> n8n tracking webhook -> Kommo, then Supabase email-only notification
# low-qualification lead: site (Vite) -> Supabase send-contact-email -> Resend only

# -----------------------------------------------------------------------------
# WEBSITE RUNTIME VALUES
# Only VITE_* variables are exposed to the browser by Vite.
# -----------------------------------------------------------------------------
VITE_SITE_BASE_URL=https://ebgreenimmigration.com
VITE_TRACKING_BACKEND_MODE=n8n_with_supabase_email_notification
VITE_N8N_WEBHOOK_URL=https://n8n.srv1283251.hstgr.cloud/webhook/website-form-lead-tracking-v1
VITE_GTM_CONTAINER_ID=GTM-N2BG96B5
VITE_GA4_MEASUREMENT_ID=G-E95KQSN0BH
VITE_META_PIXEL_ID=989361967125949

# Optional for validation in Events Manager. Only fill if you have Meta access.
VITE_META_TEST_EVENT_CODE=

# -----------------------------------------------------------------------------
# N8N WORKFLOW REFERENCE
# The direct workflow is the runtime CRM path for qualified leads. The
# compatibility workflow remains active for the deployed Supabase function and
# WhatsApp/legacy form paths.
# -----------------------------------------------------------------------------
N8N_RUNTIME_WORKFLOW_NAME=EBGREEN — Website Form → Kommo Tracking v1
N8N_RUNTIME_WORKFLOW_ID=xryAKvCbA0Zlc0aL
N8N_RUNTIME_WEBHOOK_PATH=website-form-lead-tracking-v1
N8N_COMPAT_WORKFLOW_NAME=EBGREEN — Website Form → Kommo Lead Novo Live
N8N_COMPAT_WORKFLOW_ID=tRC2f4aELOjZBpX4
N8N_COMPAT_WEBHOOK_PATH=website-form-lead

# -----------------------------------------------------------------------------
# DEPLOY / PUBLISH
# Required if you want me to put the code live, not only prepare files.
# -----------------------------------------------------------------------------
DEPLOY_PROVIDER=
DEPLOY_PROJECT_NAME=
DEPLOY_HAS_WRITE_ACCESS=

# -----------------------------------------------------------------------------
# KOMMO ACCESS
# Informational for this phase.
# The new n8n workflow already points to the active Ebgreen Kommo account.
# -----------------------------------------------------------------------------
KOMMO_SUBDOMAIN=ebgreen
KOMMO_UI_ADMIN_ACCESS=yes

# -----------------------------------------------------------------------------
# KOMMO LEAD FIELDS USED BY THE NEW N8N WORKFLOW
# These IDs already exist in the current Ebgreen Kommo account.
# -----------------------------------------------------------------------------
KOMMO_FIELD_EMAIL_ID=3878723
KOMMO_FIELD_CHANNEL_ID=3878745
KOMMO_FIELD_ORIGIN_PHRASE_ID=3878729
KOMMO_FIELD_STATUS_TEXT_ID=3878733
KOMMO_FIELD_VISA_CLASSIFICATION_ID=3881267
KOMMO_FIELD_UTM_SOURCE_ID=2634226
KOMMO_FIELD_UTM_MEDIUM_ID=2634222
KOMMO_FIELD_UTM_CAMPAIGN_ID=2634224
KOMMO_FIELD_UTM_TERM_ID=2634228
KOMMO_FIELD_UTM_CONTENT_ID=2634220
KOMMO_FIELD_UTM_REFERRER_ID=2634230
KOMMO_FIELD_REFERRER_ID=2634232
KOMMO_FIELD_GCLID_ID=2634236
KOMMO_FIELD_FBCLID_ID=2634238

# -----------------------------------------------------------------------------
# TRACKING DATA STORED IN LEAD NOTE IN THIS PHASE
# We are not creating extra Kommo custom fields for these yet.
# -----------------------------------------------------------------------------
KOMMO_TRACKING_NOTE_FIELDS=landing_page,event_id,event_source_url,client_ip,user_agent,qualification,qualificationReason

# -----------------------------------------------------------------------------
# BLOCKED / OUT OF SCOPE RIGHT NOW
# -----------------------------------------------------------------------------
# META_CAPI_ACCESS_TOKEN=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
